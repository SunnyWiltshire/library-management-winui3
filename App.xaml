<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Biblioteca.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Muxc="using:Microsoft.UI.Xaml.Controls">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <Muxc:XamlControlsResources/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Colores base -->
            <Color x:Key="PrimaryBg">#121212</Color>
            <Color x:Key="SurfaceBg">#1E1E1E</Color>
            <Color x:Key="AccentRed">#C62828</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryBg}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceBg}"/>
            <SolidColorBrush x:Key="AccentBrush"  Color="{StaticResource AccentRed}"/>

            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background"    Value="{StaticResource AccentBrush}"/>
                <Setter Property="Foreground"    Value="White"/>
                <Setter Property="CornerRadius"  Value="6"/>
                <Setter Property="Padding"       Value="12,8"/>
            </Style>

            <!-- ── AutoSuggestBox dropdown oscuro ── -->
            <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBackground"
                             Color="#10142B"/>
            <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBorderBrush"
                             Color="#507C5CFF"/>

            <SolidColorBrush x:Key="ListViewItemBackground"
                             Color="Transparent"/>
            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver"
                             Color="#287C5CFF"/>
            <SolidColorBrush x:Key="ListViewItemBackgroundSelected"
                             Color="#407C5CFF"/>
            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver"
                             Color="#557C5CFF"/>
            <SolidColorBrush x:Key="ListViewItemForeground"
                             Color="#C8C3FF"/>
            <SolidColorBrush x:Key="ListViewItemForegroundPointerOver"
                             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="ListViewItemForegroundSelected"
                             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver"
                             Color="#FFFFFF"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>