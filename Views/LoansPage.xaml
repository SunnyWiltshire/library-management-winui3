<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Biblioteca.Views.LoansPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Biblioteca.Models">

    <Page.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10"/>
            <Setter Property="FontWeight"        Value="SemiBold"/>
            <Setter Property="Foreground"        Value="#404870"/>
            <Setter Property="CharacterSpacing"  Value="80"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="FiltroBtn" TargetType="Button">
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>
    </Page.Resources>

    <Grid x:Name="RootGrid">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0F1E" Offset="0"/>
                <GradientStop Color="#10142B" Offset="0.5"/>
                <GradientStop Color="#080B18" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Padding="32,28,32,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Text="Préstamos" FontSize="28" FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#C5B8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock x:Name="SubtitleText"
                               Text="Gestión de préstamos"
                               FontSize="13" Foreground="#5A6380"/>
                </StackPanel>

                <!-- BÚSQUEDA -->
                <TextBox x:Name="SearchBox"
                         PlaceholderText="Buscar por libro o usuario..."
                         Height="42" MaxWidth="420"
                         HorizontalAlignment="Left"
                         Padding="14,0" FontSize="13"
                         CornerRadius="12" BorderThickness="1"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <ResourceDictionary>
                            <SolidColorBrush x:Key="TextControlBackground"                       Color="#14192E"/>
                            <SolidColorBrush x:Key="TextControlBackgroundFocused"                Color="#1A2038"/>
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver"            Color="#171D30"/>
                            <SolidColorBrush x:Key="TextControlBorderBrush"                      Color="#252C4A"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"           Color="#3A4470"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused"               Color="#7C5CFF"/>
                            <SolidColorBrush x:Key="TextControlForeground"                       Color="#E8ECF8"/>
                            <SolidColorBrush x:Key="TextControlForegroundFocused"                Color="#F5F7FF"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForeground"            Color="#556B7AAA"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"     Color="#446B7AAA"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#556B7AAA"/>
                            <SolidColorBrush x:Key="TextControlSelectionHighlightColor"          Color="#7C5CFF"/>
                        </ResourceDictionary>
                    </TextBox.Resources>
                </TextBox>

                <!-- FILTROS DE ESTADO -->
                <StackPanel Orientation="Horizontal" Spacing="8">

                    <Button x:Name="BtnFiltroTodos"
                            Style="{StaticResource FiltroBtn}"
                            Click="FiltroTodos_Click">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#3C7C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#507C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#287C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#787C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#A07C5CFF"/>
                                <SolidColorBrush x:Key="ButtonForeground"             Color="#C5B8FF"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#E0D8FF"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <TextBlock Text="Todos" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#C5B8FF"/>
                    </Button>

                    <Button x:Name="BtnFiltroActivos"
                            Style="{StaticResource FiltroBtn}"
                            Click="FiltroActivos_Click">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#1AFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#2822D3EE"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#1822D3EE"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#1EFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#5022D3EE"/>
                                <SolidColorBrush x:Key="ButtonForeground"             Color="#8B8FC4"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#22D3EE"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <TextBlock Text="Activos" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#8B8FC4"/>
                    </Button>

                    <Button x:Name="BtnFiltroVencidos"
                            Style="{StaticResource FiltroBtn}"
                            Click="FiltroVencidos_Click">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#1AFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#28FFB850"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#18FFB850"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#1EFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#50FFB850"/>
                                <SolidColorBrush x:Key="ButtonForeground"             Color="#8B8FC4"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#FFB850"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <TextBlock Text="Vencidos" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#8B8FC4"/>
                    </Button>

                    <Button x:Name="BtnFiltroDevueltos"
                            Style="{StaticResource FiltroBtn}"
                            Click="FiltroDevueltos_Click">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#1AFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#2822EEB8"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#1822EEB8"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#1EFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#5022EEB8"/>
                                <SolidColorBrush x:Key="ButtonForeground"             Color="#8B8FC4"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#22EEB8"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <TextBlock Text="Devueltos" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#8B8FC4"/>
                    </Button>

                    <Button x:Name="BtnFiltroHistorial"
                            Style="{StaticResource FiltroBtn}"
                            Click="FiltroHistorial_Click">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#1AFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#28C55CFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#18C55CFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#1EFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#50C55CFF"/>
                                <SolidColorBrush x:Key="ButtonForeground"             Color="#8B8FC4"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#C55CFF"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <TextBlock Text="Historial" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#8B8FC4"/>
                    </Button>

                </StackPanel>
            </StackPanel>

            <!-- Botón nuevo préstamo -->
            <Border Grid.Column="1" VerticalAlignment="Top"
                    CornerRadius="13" Padding="1.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C5CFF" Offset="0"/>
                        <GradientStop Color="#22D3EE" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Button x:Name="AddButton" Height="42" Padding="20,0"
                        CornerRadius="12" Click="Add_Click">
                    <Button.Resources>
                        <ResourceDictionary>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="#7C5CFF"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#9570FF"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#6346E0"/>
                            <SolidColorBrush x:Key="ButtonForeground"             Color="#FFFFFF"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#FFFFFF"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="#DDD8FF"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled"    Color="Transparent"/>
                        </ResourceDictionary>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="#FFFFFF"/>
                        <TextBlock Text="Nuevo préstamo" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- TABLA -->
        <Border Grid.Row="1" Margin="32,0,32,32"
                CornerRadius="16" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#141830" Offset="0"/>
                    <GradientStop Color="#0F1228" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#30FFFFFF" Offset="0"/>
                    <GradientStop Color="#08FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER TABLA -->
                <Border CornerRadius="16,16,0,0" Padding="24,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#1A1F3A" Offset="0"/>
                            <GradientStop Color="#161B35" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Height="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="LIBRO"      Grid.Column="0" Style="{StaticResource HeaderStyle}"/>
                        <TextBlock Text="USUARIO"    Grid.Column="1" Style="{StaticResource HeaderStyle}"/>
                        <TextBlock Text="PRÉSTAMO"   Grid.Column="2" Style="{StaticResource HeaderStyle}"/>
                        <TextBlock Text="DEVOLUCIÓN" Grid.Column="3" Style="{StaticResource HeaderStyle}"/>
                        <TextBlock Text="ESTADO"     Grid.Column="4" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                        <TextBlock Text="ACCIONES"   Grid.Column="5" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- FILAS -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <ResourceDictionary>
                            <SolidColorBrush x:Key="ScrollBarThumbFill"            Color="#7C5CFF"/>
                            <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="#9570FF"/>
                            <SolidColorBrush x:Key="ScrollBarThumbFillPressed"     Color="#6346E0"/>
                            <SolidColorBrush x:Key="ScrollBarTrackFill"            Color="#14192E"/>
                            <SolidColorBrush x:Key="ScrollBarTrackFillPointerOver" Color="#1A2038"/>
                        </ResourceDictionary>
                    </ScrollViewer.Resources>

                    <ItemsControl x:Name="LoansList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:Loan">
                                <Border x:Name="RowBorder"
                                        Padding="24,0"
                                        BorderThickness="0,0,0,1"
                                        PointerEntered="Row_PointerEntered"
                                        PointerExited="Row_PointerExited">
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#12FFFFFF"/>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <SolidColorBrush Color="Transparent"/>
                                    </Border.Background>

                                    <Grid Height="58">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- LIBRO -->
                                        <StackPanel Grid.Column="0" Orientation="Horizontal"
                                                    Spacing="10" VerticalAlignment="Center">
                                            <Border Width="32" Height="32" CornerRadius="10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#3D1F8C" Offset="0"/>
                                                        <GradientStop Color="#7C5CFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <FontIcon Glyph="&#xE736;" FontSize="14"
                                                          Foreground="White"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Libro}"
                                                       Foreground="#E0DCFF" FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <!-- USUARIO -->
                                        <TextBlock Grid.Column="1" Text="{x:Bind Usuario}"
                                                   Foreground="#8B8FC4" FontSize="13"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- FECHA PRÉSTAMO -->
                                        <TextBlock Grid.Column="2" Text="{x:Bind FechaPrestamo}"
                                                   Foreground="#8B8FC4" FontSize="12"
                                                   VerticalAlignment="Center"/>

                                        <!-- FECHA DEVOLUCIÓN -->
                                        <TextBlock Grid.Column="3" Text="{x:Bind FechaDevolucion}"
                                                   Foreground="#8B8FC4" FontSize="12"
                                                   VerticalAlignment="Center"/>

                                        <!-- ESTADO -->
                                        <Border Grid.Column="4" CornerRadius="8"
                                                Padding="8,3" HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Background="{x:Bind EstadoFondo}"
                                                BorderBrush="{x:Bind EstadoBorde}"
                                                BorderThickness="1">
                                            <TextBlock Text="{x:Bind EstadoTexto}"
                                                       FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{x:Bind EstadoColorTexto}"/>
                                        </Border>

                                        <!-- ACCIONES -->
                                        <StackPanel Grid.Column="5"
                                                    Orientation="Horizontal" Spacing="5"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">

                                            <!-- DEVOLVER -->
                                            <Button Tag="{x:Bind Id}" Click="Return_Click"
                                                    Width="32" Height="32" Padding="0"
                                                    CornerRadius="9"
                                                    ToolTipService.ToolTip="Devolver">
                                                <Button.Resources>
                                                    <ResourceDictionary>
                                                        <SolidColorBrush x:Key="ButtonBackground"             Color="#2822D3EE"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#4422D3EE"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#1822D3EE"/>
                                                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#4022D3EE"/>
                                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#7022D3EE"/>
                                                    </ResourceDictionary>
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE72C;" FontSize="13" Foreground="#22D3EE"/>
                                            </Button>

                                            <!-- ELIMINAR -->
                                            <Button Tag="{x:Bind Id}" Click="Delete_Click"
                                                    Width="32" Height="32" Padding="0"
                                                    CornerRadius="9"
                                                    ToolTipService.ToolTip="Eliminar">
                                                <Button.Resources>
                                                    <ResourceDictionary>
                                                        <SolidColorBrush x:Key="ButtonBackground"             Color="#28FF5F7A"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#44FF5F7A"/>
                                                        <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#18FF5F7A"/>
                                                        <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#40FF5F7A"/>
                                                        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#70FF5F7A"/>
                                                    </ResourceDictionary>
                                                </Button.Resources>
                                                <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="#FF5F7A"/>
                                            </Button>

                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- TOAST -->
        <Border x:Name="ToastContainer"
                Grid.Row="1"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,28"
                Opacity="0"
                IsHitTestVisible="False"
                CornerRadius="14"
                Padding="20,13"
                Translation="0,0,128">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EE10142B" Offset="0"/>
                    <GradientStop Color="#EE0D0F1E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C5CFF" Offset="0"/>
                    <GradientStop Color="#22D3EE" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>1</Thickness>
            </Border.BorderThickness>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon x:Name="ToastIcono"
                          FontSize="16"
                          VerticalAlignment="Center"
                          Foreground="#22D3EE"/>
                <TextBlock x:Name="ToastTexto"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#E0DCFF"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>