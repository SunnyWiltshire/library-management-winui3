<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Biblioteca.Views.BooksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Biblioteca.Models">

    <Grid x:Name="RootGrid">

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0F1E" Offset="0"/>
                <GradientStop Color="#10142B" Offset="0.5"/>
                <GradientStop Color="#080B18" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Grid Padding="32,28,32,20" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="Libros" FontSize="28" FontWeight="Bold">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#C5B8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock x:Name="SubtitleText"
                               Text="Catálogo de libros"
                               FontSize="13" Foreground="#5A6380"/>
                </StackPanel>

                <TextBox x:Name="SearchBox"
                         PlaceholderText="Buscar por título o autor..."
                         Height="42" MaxWidth="420"
                         HorizontalAlignment="Left"
                         Padding="14,0" FontSize="13"
                         CornerRadius="12" BorderThickness="1"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged">
                    <TextBox.Resources>
                        <ResourceDictionary>
                            <SolidColorBrush x:Key="TextControlBackground"                       Color="#14192E"/>
                            <SolidColorBrush x:Key="TextControlBackgroundFocused"                Color="#1A2038"/>
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver"            Color="#171D30"/>
                            <SolidColorBrush x:Key="TextControlBorderBrush"                      Color="#252C4A"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"           Color="#3A4470"/>
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused"               Color="#7C5CFF"/>
                            <SolidColorBrush x:Key="TextControlForeground"                       Color="#E8ECF8"/>
                            <SolidColorBrush x:Key="TextControlForegroundFocused"                Color="#F5F7FF"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForeground"            Color="#556B7AAA"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"     Color="#446B7AAA"/>
                            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#556B7AAA"/>
                            <SolidColorBrush x:Key="TextControlSelectionHighlightColor"          Color="#7C5CFF"/>
                        </ResourceDictionary>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>

            <!-- Botón agregar -->
            <Border Grid.Column="1" VerticalAlignment="Bottom"
                    CornerRadius="13" Padding="1.5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#7C5CFF" Offset="0"/>
                        <GradientStop Color="#22D3EE" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Button x:Name="AddButton" Height="42" Padding="20,0"
                        CornerRadius="12" Click="Add_Click">
                    <Button.Resources>
                        <ResourceDictionary>
                            <SolidColorBrush x:Key="ButtonBackground"             Color="#7C5CFF"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#9570FF"/>
                            <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#6346E0"/>
                            <SolidColorBrush x:Key="ButtonForeground"             Color="#FFFFFF"/>
                            <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#FFFFFF"/>
                            <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="#DDD8FF"/>
                            <SolidColorBrush x:Key="ButtonBorderBrush"            Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="Transparent"/>
                            <SolidColorBrush x:Key="ButtonBorderBrushDisabled"    Color="Transparent"/>
                        </ResourceDictionary>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" Foreground="#FFFFFF"/>
                        <TextBlock Text="Agregar libro" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </Button>
            </Border>
        </Grid>

        <!-- GRID DE TARJETAS -->
        <GridView Grid.Row="1"
                  x:Name="BooksGrid"
                  Padding="32,24,32,32"
                  SelectionMode="None"
                  IsItemClickEnabled="False"
                  HorizontalAlignment="Center"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">

            <GridView.Resources>
                <ResourceDictionary>
                    <SolidColorBrush x:Key="GridViewItemBackground"                    Color="Transparent"/>
                    <SolidColorBrush x:Key="GridViewItemBackgroundPointerOver"         Color="Transparent"/>
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelected"            Color="Transparent"/>
                    <SolidColorBrush x:Key="GridViewItemBackgroundSelectedPointerOver" Color="Transparent"/>
                    <SolidColorBrush x:Key="GridViewItemBorderBrush"                   Color="Transparent"/>
                    <SolidColorBrush x:Key="GridViewItemBorderBrushPointerOver"        Color="Transparent"/>
                    <SolidColorBrush x:Key="GridViewItemBorderBrushSelected"           Color="Transparent"/>
                </ResourceDictionary>
            </GridView.Resources>

            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin"  Value="0,0,18,18"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="VerticalContentAlignment"   Value="Stretch"/>
                </Style>
            </GridView.ItemContainerStyle>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Book">

                    <Border x:Name="CardBorder"
                            Width="200" CornerRadius="16"
                            BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5"
                            Translation="0,0,32"
                            PointerEntered="Card_PointerEntered"
                            PointerExited="Card_PointerExited">

                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>

                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>

                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1A1F3A" Offset="0"/>
                                <GradientStop Color="#141830" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#30FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>

                        <StackPanel>

                            <!-- PORTADA -->
                            <Grid Height="240">

                                <!-- FALLBACK -->
                                <Border x:Name="FallbackCover"
                                        CornerRadius="16,16,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{x:Bind CoverColor}"  Offset="0"/>
                                            <GradientStop Color="{x:Bind CoverColor2}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Ellipse Width="140" Height="140"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Top"
                                                 Margin="0,-40,-40,0"
                                                 Opacity="0.12" Fill="White"/>
                                        <Ellipse Width="90" Height="90"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Bottom"
                                                 Margin="-25,0,0,15"
                                                 Opacity="0.08" Fill="White"/>
                                        <Ellipse Width="60" Height="60"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Top"
                                                 Margin="0,20,0,0"
                                                 Opacity="0.06" Fill="White"/>
                                        <TextBlock Text="{x:Bind Inicial}"
                                                   FontSize="80" FontWeight="Bold"
                                                   Foreground="White" Opacity="0.85"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind Anio}"
                                                   FontSize="11" Foreground="#AAFFFFFF"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Margin="0,0,12,10"/>
                                    </Grid>
                                </Border>

                                <!-- IMAGEN REAL -->
                                <Image x:Name="ImgPortada"
                                       Stretch="UniformToFill"
                                       Visibility="Collapsed"/>

                                <!-- OVERLAY hover -->
                                <Border x:Name="HoverOverlay"
                                        CornerRadius="16,16,0,0"
                                        Opacity="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#CC0D0F1E" Offset="0"/>
                                            <GradientStop Color="#EE080B18" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="10"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">

                                        <Button Tag="{x:Bind Id}"
                                                Click="Edit_Click"
                                                Width="44" Height="44"
                                                Padding="0" CornerRadius="12"
                                                ToolTipService.ToolTip="Editar">
                                            <Button.Resources>
                                                <ResourceDictionary>
                                                    <SolidColorBrush x:Key="ButtonBackground"             Color="#447C5CFF"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#669570FF"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#336346E0"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#507C5CFF"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#807C5CFF"/>
                                                </ResourceDictionary>
                                            </Button.Resources>
                                            <FontIcon Glyph="&#xE70F;" FontSize="16" Foreground="#C5B8FF"/>
                                        </Button>

                                        <Button Tag="{x:Bind Id}"
                                                Click="Delete_Click"
                                                Width="44" Height="44"
                                                Padding="0" CornerRadius="12"
                                                ToolTipService.ToolTip="Eliminar">
                                            <Button.Resources>
                                                <ResourceDictionary>
                                                    <SolidColorBrush x:Key="ButtonBackground"             Color="#44FF5F7A"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#66FF5F7A"/>
                                                    <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#33FF5F7A"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#50FF5F7A"/>
                                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#80FF5F7A"/>
                                                </ResourceDictionary>
                                            </Button.Resources>
                                            <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="#FF5F7A"/>
                                        </Button>

                                    </StackPanel>
                                </Border>

                            </Grid>

                            <!-- INFO -->
                            <StackPanel Padding="14,12,14,14" Spacing="6">

                                <TextBlock Text="{x:Bind Titulo}"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E0DCFF"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="2" TextWrapping="Wrap"/>

                                <TextBlock Text="{x:Bind Autor}"
                                           FontSize="11" Foreground="#6A7499"
                                           TextTrimming="CharacterEllipsis"/>

                                <Border CornerRadius="6" Padding="8,3"
                                        HorizontalAlignment="Left"
                                        Margin="0,2,0,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#287C5CFF" Offset="0"/>
                                            <GradientStop Color="#2822D3EE" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="{x:Bind Categoria}"
                                               FontSize="10" FontWeight="SemiBold"
                                               Foreground="#C5B8FF" CharacterSpacing="40"/>
                                </Border>

                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Disponibles"
                                               FontSize="10" Foreground="#404870"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" CornerRadius="6" Padding="8,2">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#2022D3EE" Offset="0"/>
                                                <GradientStop Color="#1010C8A0" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="{x:Bind Disponibles}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="#22D3EE"/>
                                    </Border>
                                </Grid>

                            </StackPanel>
                        </StackPanel>
                    </Border>

                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <!-- TOAST -->
        <Border x:Name="ToastContainer"
                Grid.Row="1"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,28"
                Opacity="0"
                IsHitTestVisible="False"
                CornerRadius="14"
                Padding="20,13"
                Translation="0,0,128">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EE10142B" Offset="0"/>
                    <GradientStop Color="#EE0D0F1E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C5CFF" Offset="0"/>
                    <GradientStop Color="#22D3EE" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.BorderThickness>
                <Thickness>1</Thickness>
            </Border.BorderThickness>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon x:Name="ToastIcono"
                          FontSize="16"
                          VerticalAlignment="Center"
                          Foreground="#22D3EE"/>
                <TextBlock x:Name="ToastTexto"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#E0DCFF"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Page>