<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Biblioteca.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:Biblioteca.Views"
    Title="OpenBook">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0F1E" Offset="0"/>
                <GradientStop Color="#10142B" Offset="0.5"/>
                <GradientStop Color="#080B18" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Orbe violeta -->
        <Ellipse Grid.RowSpan="2"
                 Width="600" Height="600"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-250,-250,0,0" Opacity="0.12">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#7C5CFF" Offset="0"/>
                    <GradientStop Color="#007C5CFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- Orbe cian -->
        <Ellipse Grid.RowSpan="2"
                 Width="500" Height="500"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-160,-160" Opacity="0.10">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#22D3EE" Offset="0"/>
                    <GradientStop Color="#0022D3EE" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <!-- ===== NAVBAR SUPERIOR ===== -->
        <Border Grid.Row="0" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#120F28" Offset="0"/>
                    <GradientStop Color="#0E1224" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#007C5CFF" Offset="0"/>
                    <GradientStop Color="#407C5CFF" Offset="0.5"/>
                    <GradientStop Color="#007C5CFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid Padding="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo izquierda -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">

                    <Border Width="42"
                            Height="42"
                            CornerRadius="12"
                            Background="#162033"
                            BorderBrush="#2E3B5B"
                            BorderThickness="1">

                                            <Border.Shadow>
                                                <ThemeShadow/>
                                            </Border.Shadow>

                                            <Image Source="ms-appx:///Assets/Logo.png"
                               Stretch="Uniform"
                               Margin="7"/>
                    </Border>

                    <TextBlock Text="OpenBook"
                               FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center">
                        <TextBlock.Foreground>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#C5B8FF" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>

                </StackPanel>

                <!-- Tabs centrados -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="4">

                    <Button x:Name="BtnDashboard"
                            Tag="dashboard"
                            Click="NavBtn_Click"
                            CornerRadius="10"
                            Height="38"
                            Padding="16,0">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"            Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#147C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#0D7C5CFF"/>
                                <SolidColorBrush x:Key="ButtonForeground"            Color="#6A7499"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#C5B8FF"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="#A090EE"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"           Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"    Color="Transparent"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE80F;" FontSize="14"/>
                            <TextBlock Text="Dashboard" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnBooks"
                            Tag="books"
                            Click="NavBtn_Click"
                            CornerRadius="10"
                            Height="38"
                            Padding="16,0">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"            Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#147C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#0D7C5CFF"/>
                                <SolidColorBrush x:Key="ButtonForeground"            Color="#6A7499"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#C5B8FF"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="#A090EE"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"           Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"    Color="Transparent"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE736;" FontSize="14"/>
                            <TextBlock Text="Libros" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnUsers"
                            Tag="users"
                            Click="NavBtn_Click"
                            CornerRadius="10"
                            Height="38"
                            Padding="16,0">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"            Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#147C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#0D7C5CFF"/>
                                <SolidColorBrush x:Key="ButtonForeground"            Color="#6A7499"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#C5B8FF"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="#A090EE"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"           Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"    Color="Transparent"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE716;" FontSize="14"/>
                            <TextBlock Text="Usuarios" FontSize="13"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnLoans"
                            Tag="loans"
                            Click="NavBtn_Click"
                            CornerRadius="10"
                            Height="38"
                            Padding="16,0">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"            Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#147C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"     Color="#0D7C5CFF"/>
                                <SolidColorBrush x:Key="ButtonForeground"            Color="#6A7499"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#C5B8FF"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed"     Color="#A090EE"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"           Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"    Color="Transparent"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE8EE;" FontSize="14"/>
                            <TextBlock Text="Préstamos" FontSize="13"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Usuario + logout derecha -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="12">

                    <!-- Info usuario -->
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock x:Name="WelcomeText"
                                   Text="Usuario"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#E0DCFF"
                                   HorizontalAlignment="Right"/>
                        <Border CornerRadius="4" Padding="6,1,6,1"
                                HorizontalAlignment="Right">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#287C5CFF" Offset="0"/>
                                    <GradientStop Color="#2822D3EE" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock x:Name="RoleText"
                                       Text="ROL"
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       CharacterSpacing="80"
                                       Foreground="#C5B8FF"/>
                        </Border>
                    </StackPanel>

                    <!-- Separador -->
                    <Border Width="1" Height="28" Opacity="0.15"
                            Background="#FFFFFF"/>

                    <!-- Botón logout -->
                    <Button Tag="logout"
                            Click="NavBtn_Click"
                            CornerRadius="10"
                            Height="36"
                            Padding="12,0"
                            ToolTipService.ToolTip="Cerrar sesión">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground"             Color="#14FF5F7A"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver"  Color="#22FF5F7A"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed"      Color="#0DFF5F7A"/>
                                <SolidColorBrush x:Key="ButtonForeground"             Color="#FF5F7A"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver"  Color="#FF8099"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed"      Color="#E04060"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush"            Color="#22FF5F7A"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#44FF5F7A"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed"     Color="#11FF5F7A"/>
                            </ResourceDictionary>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8FB;" FontSize="13" Foreground="#FF5F7A"/>
                            <TextBlock Text="Salir" FontSize="12" Foreground="#FF5F7A"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== CONTENIDO ===== -->
        <Frame x:Name="ContentFrame" Grid.Row="1"/>

    </Grid>
</Window>