<Window
    x:Class="Biblioteca.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OpenBook">

    <Grid x:Name="RootGrid">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D0F1E" Offset="0"/>
                <GradientStop Color="#10142B" Offset="0.5"/>
                <GradientStop Color="#080B18" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse x:Name="OrbeVioleta"
                 Width="500" Height="500"
                 HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-200,-200,0,0" Opacity="0.18">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#7C5CFF" Offset="0"/>
                    <GradientStop Color="#007C5CFF" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse x:Name="OrbeCian"
                 Width="460" Height="460"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,-180,-180" Opacity="0.14">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#22D3EE" Offset="0"/>
                    <GradientStop Color="#0022D3EE" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse x:Name="OrbeRosa"
                 Width="300" Height="300"
                 HorizontalAlignment="Right" VerticalAlignment="Top"
                 Margin="0,60,-80,0" Opacity="0.08">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#FF6B9D" Offset="0"/>
                    <GradientStop Color="#00FF6B9D" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Border x:Name="TarjetaLogin"
                Width="400"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                CornerRadius="24" Padding="36,32,36,32" BorderThickness="1">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#22253A60" Offset="0"/>
                    <GradientStop Color="#18192D50" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#50FFFFFF" Offset="0"/>
                    <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#28FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <StackPanel Spacing="0">

                <!-- LOGO -->
                <Border Width="38"
                        Height="38"
                        CornerRadius="12">

                          <Image Source="Assets/logo.png"
                           Stretch="UniformToFill"/>
                </Border>

                <!-- TITULO -->
                <TextBlock Text="OpenBook"
                           FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,6">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#C5B8FF" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>

                <!-- SUBTITULO typing effect -->
                <TextBlock x:Name="SubtitleText"
                           Text=""
                           FontSize="13" Foreground="#5A6380"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- LABEL USUARIO -->
                <TextBlock x:Name="LabelUsuario"
                           Text="USUARIO"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#404870" CharacterSpacing="80"
                           Margin="2,0,0,8" Opacity="0"/>

                <!-- CAMPO USUARIO -->
                <Grid x:Name="GridUsuario" Margin="0,0,0,20" Opacity="0">
                    <Path Width="16" Height="16"
                          HorizontalAlignment="Left" VerticalAlignment="Center"
                          Margin="14,0,0,0" Fill="#4A5480"
                          IsHitTestVisible="False" Stretch="Uniform"
                          Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>

                    <TextBox x:Name="UsernameBox"
                             PlaceholderText="Ingresa tu usuario"
                             Height="48"
                             MaxLength="20"
                             Padding="42,14,36,0"
                             FontSize="13"
                             CornerRadius="12"
                             BorderThickness="1"
                             VerticalContentAlignment="Center"
                             BeforeTextChanging="UsernameBox_BeforeTextChanging"
                             LostFocus="UsernameBox_LostFocus"
                             KeyDown="Input_KeyDown">
                        <TextBox.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="TextControlBackground" Color="#14192E"/>
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#1A2038"/>
                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#171D30"/>
                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#252C4A"/>
                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#3A4470"/>
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#7C5CFF"/>
                                <SolidColorBrush x:Key="TextControlForeground" Color="#E8ECF8"/>
                                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#F5F7FF"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#6B7AAA"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#6B7AAA"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6B7AAA"/>
                                <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#7C5CFF"/>
                            </ResourceDictionary>
                        </TextBox.Resources>
                    </TextBox>

                    <FontIcon x:Name="LoginUserIcon"
                              FontSize="14" Opacity="0"
                              HorizontalAlignment="Right" VerticalAlignment="Center"
                              Margin="0,0,12,0">
                        <FontIcon.RenderTransform>
                            <ScaleTransform ScaleX="0.7" ScaleY="0.7"/>
                        </FontIcon.RenderTransform>
                    </FontIcon>
                </Grid>

                <!-- LABEL PASSWORD -->
                <TextBlock x:Name="LabelPassword"
                           Text="CONTRASEÑA"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#404870" CharacterSpacing="80"
                           Margin="2,0,0,8" Opacity="0"/>

                <!-- CAMPO PASSWORD -->
                <Grid x:Name="GridPassword" Margin="0,0,0,28" Opacity="0">
                    <Path Width="16" Height="16"
                          HorizontalAlignment="Left" VerticalAlignment="Center"
                          Margin="14,0,0,0" Fill="#4A5480"
                          IsHitTestVisible="False" Stretch="Uniform"
                          Data="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/>

                    <PasswordBox x:Name="PasswordBox"
                                 PlaceholderText="Ingresa tu contraseña"
                                 Height="48"
                                 Padding="42,14,14,0"
                                 FontSize="13"
                                 CornerRadius="12"
                                 BorderThickness="1"
                                 VerticalContentAlignment="Center"
                                 KeyDown="Input_KeyDown">
                        <PasswordBox.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="TextControlBackground" Color="#14192E"/>
                                <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#1A2038"/>
                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#171D30"/>
                                <SolidColorBrush x:Key="TextControlBorderBrush" Color="#252C4A"/>
                                <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#3A4470"/>
                                <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#7C5CFF"/>
                                <SolidColorBrush x:Key="TextControlForeground" Color="#E8ECF8"/>
                                <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#F5F7FF"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#6B7AAA"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#6B7AAA"/>
                                <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6B7AAA"/>
                                <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#7C5CFF"/>
                            </ResourceDictionary>
                        </PasswordBox.Resources>
                    </PasswordBox>
                </Grid>

                <!-- BOTÓN PRIMARIO con shimmer -->
                <Grid x:Name="GridBotonLogin" Margin="0,0,0,12" Opacity="0">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="ScaleBotonLogin" ScaleX="1" ScaleY="1"/>
                    </Grid.RenderTransform>
                    <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>

                    <Border x:Name="BordeDegradado" CornerRadius="14" Padding="1.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C5CFF" Offset="0"/>
                                <GradientStop Color="#22D3EE" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Content="Iniciar sesión"
                                Height="46" HorizontalAlignment="Stretch"
                                Click="Login_Click" CornerRadius="13"
                                FontSize="14" FontWeight="SemiBold">
                            <Button.Resources>
                                <ResourceDictionary>
                                    <SolidColorBrush x:Key="ButtonBackground" Color="#7C5CFF"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#9570FF"/>
                                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#6346E0"/>
                                    <SolidColorBrush x:Key="ButtonForeground" Color="#FFFFFF"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#FFFFFF"/>
                                    <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#DDD8FF"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent"/>
                                    <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent"/>
                                </ResourceDictionary>
                            </Button.Resources>
                        </Button>
                    </Border>

                    <!-- SHIMMER overlay -->
                    <Border CornerRadius="14" IsHitTestVisible="False">
                        <Border x:Name="ShimmerBar"
                                Width="60" Height="46"
                                HorizontalAlignment="Left"
                                CornerRadius="14"
                                Opacity="0.25">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#FFFFFF" Offset="0.5"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.RenderTransform>
                                <TranslateTransform x:Name="ShimmerTranslate" X="-80"/>
                            </Border.RenderTransform>
                        </Border>
                    </Border>
                </Grid>

                <!-- BOTÓN SECUNDARIO -->
                <Grid x:Name="GridBotonRegister" Opacity="0">
                    <Grid.RenderTransform>
                        <ScaleTransform x:Name="ScaleBotonRegister" ScaleX="1" ScaleY="1"/>
                    </Grid.RenderTransform>
                    <Grid.RenderTransformOrigin>0.5,0.5</Grid.RenderTransformOrigin>

                    <Button Content="Crear cuenta nueva"
                            Height="44" HorizontalAlignment="Stretch"
                            Click="Register_Click" CornerRadius="12"
                            FontSize="13" FontWeight="Medium"
                            PointerEntered="BtnRegister_PointerEntered"
                            PointerExited="BtnRegister_PointerExited">
                        <Button.Resources>
                            <ResourceDictionary>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#0CFFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#16FFFFFF"/>
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#07FFFFFF"/>
                                <SolidColorBrush x:Key="ButtonForeground" Color="#6A7499"/>
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#BCC4E0"/>
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="#9098B8"/>
                                <SolidColorBrush x:Key="ButtonBorderBrush" Color="#1C2848"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#507C5CFF"/>
                                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#307C5CFF"/>
                            </ResourceDictionary>
                        </Button.Resources>
                    </Button>
                </Grid>

                <Border Height="1" Margin="0,24,0,0" Opacity="0.10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <TextBlock x:Name="ErrorText"
                           Foreground="#FF5F7A" FontSize="12"
                           TextAlignment="Center" TextWrapping="Wrap"
                           Margin="0,14,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>